<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ResolutionTimeDays__c</fullName>
    <label>Resolution Time (Days)</label>
    <description>Calculated field: days from case creation to resolution</description>
    <type>Formula</type>
    <formula>IF(NOT(ISBLANK(ResolutionDate__c)), (ResolutionDate__c - CreatedDate) / 86400, NULL)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <returnType>Number</returnType>
    <precision>18</precision>
    <scale>2</scale>
</CustomField>
